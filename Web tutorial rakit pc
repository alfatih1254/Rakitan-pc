const tipsData = [
  { icon: '', title: 'Listrik Statis', desc: 'Selalu ground diri sebelum sentuh komponen' },
  { icon: '📸', title: 'Dokumentasi', desc: 'Foto setiap langkah untuk troubleshooting' },
  { icon: '📖', title: 'Baca Manual', desc: 'Manual motherboard adalah teman terbaikmu' },
  { icon: '🌡️', title: 'Suhu Normal', desc: 'CPU idle: 30-50°C, Load: 60-85°C' },
  { icon: '🔧', title: 'Tools Minimal', desc: 'Hanya butuh obeng Phillips #2' },
  { icon: '⚡', title: 'PSU Berkualitas', desc: 'Jangan pelit di PSU - investasi keamanan' },
  { icon: '💨', title: 'Airflow', desc: 'Intake depan, exhaust belakang/atas' },
  { icon: '🎯', title: 'Kompatibilitas', desc: 'Cek socket, form factor, dan clearance' },
  { icon: '🔄', title: 'Update Driver', desc: 'Update BIOS & driver setelah rakit' },
  { icon: '🧹', title: 'Kebersihan', desc: 'Bersihkan debu setiap 3-6 bulan' },
  { icon: '', title: 'Backup Data', desc: 'Selalu backup data penting secara rutin' },
  { icon: '🎮', title: 'Stress Test', desc: 'Test dengan Cinebench/Furmark setelah rakit' }
];

// Render components
const componentsGrid = document.getElementById('componentsGrid');
components.forEach((comp, i) => {
  const card = document.createElement('div');
  card.className = 'component-card';
  card.onclick = (event) => showComponentDetail(i, event);
  card.innerHTML = `
    <div class="comp-icon">${comp.icon}</div>
    <div class="comp-title">${comp.title}</div>
    <div class="comp-desc">${comp.desc}</div>
    <div class="comp-tags">
      ${comp.tags.map(t => `<span class="comp-tag">${t}</span>`).join('')}
    </div>
    <div class="comp-price">💰 ${comp.price}</div>
  `;
  componentsGrid.appendChild(card);
});

// Render steps
const stepsContainer = document.getElementById('stepsContainer');
steps.forEach((step, i) => {
  const card = document.createElement('div');
  card.className = 'step-card';
  card.onclick = (event) => showStepDetail(i, event);
  card.innerHTML = `
    <div class="step-number">${i + 1}</div>
    <div class="step-content">
      <div class="step-title">${step.title}</div>
      <div class="step-desc">${step.desc}</div>
      <span class="step-time">⏱️ ${step.time}</span>
    </div>
  `;
  stepsContainer.appendChild(card);
});

// Render tips
const tipsContainer = document.getElementById('tipsContainer');
tipsContainer.innerHTML = `
  <div class="tips-grid">
    ${tipsData.map(t => `
      <div class="tip-card">
        <div class="tip-icon">${t.icon}</div>
        <div class="tip-title">${t.title}</div>
        <div class="tip-desc">${t.desc}</div>
      </div>
    `).join('')}
  </div>
`;

function showSection(section) {
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  
  document.getElementById('componentsSection').style.display = section === 'components' ? 'block' : 'none';
  document.getElementById('stepsSection').style.display = section === 'steps' ? 'block' : 'none';
  document.getElementById('tipsSection').style.display = section === 'tips' ? 'block' : 'none';
  
  closeDetail();
}

function showComponentDetail(index, event) {
  const comp = components[index];
  const panel = document.getElementById('detailPanel');
  const content = document.getElementById('detailContent');

  document.querySelectorAll('.component-card').forEach(c => c.classList.remove('active'));
  event.currentTarget.classList.add('active');

  content.innerHTML = `
    <div class="detail-header">
      <div class="detail-icon">${comp.icon}</div>
      <div>
        <div class="detail-title">${comp.title}</div>
        <div class="detail-subtitle">${comp.desc}</div>
      </div>
    </div>
    <div class="detail-content">
      <div class="info-box">
        <h3>📋 Tentang ${comp.title}</h3>
        <p>${comp.detail.desc}</p>
      </div>
      <div class="info-box pink">
        <h3>⚙️ Spesifikasi Umum</h3>
        <ul>
          ${comp.detail.specs.map(s => `<li>${s}</li>`).join('')}
        </ul>
      </div>
      <div class="info-box green">
        <h3> Tips Memilih</h3>
        <ul>
          ${comp.detail.tips.map(t => `<li>${t}</li>`).join('')}
        </ul>
      </div>
      <div class="warning-box">
        <h4>⚠️ Peringatan Penting</h4>
        <p>${comp.detail.warning}</p>
      </div>
    </div>
  `;

  panel.classList.add('show');
  panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function showStepDetail(index, event) {
  const step = steps[index];
  const panel = document.getElementById('detailPanel');
  const content = document.getElementById('detailContent');

  document.querySelectorAll('.step-card').forEach(c => c.classList.remove('active'));
  event.currentTarget.classList.add('active');

  content.innerHTML = `
    <div class="detail-header">
      <div class="step-number" style="min-width:60px;height:60px;font-size:1.5em;">${index + 1}</div>
      <div>
        <div class="detail-title">${step.title}</div>
        <div class="detail-subtitle">⏱️ Estimasi: ${step.time}</div>
      </div>
    </div>
    <div class="detail-content">
      <div class="info-box">
        <h3>📖 Penjelasan</h3>
        <p>${step.detail.desc}</p>
      </div>
      <div class="info-box pink">
        <h3>✅ Checklist</h3>
        <ul>
          ${step.detail.checklist.map(c => `<li>${c}</li>`).join('')}
        </ul>
      </div>
      <div class="info-box green">
        <h3> Tips Pro</h3>
        <ul>
          ${step.detail.tips.map(t => `<li>${t}</li>`).join('')}
        </ul>
      </div>
      <div class="info-box orange">
        <h3> Langkah Selanjutnya</h3>
        <p>${index < steps.length - 1 ? `Setelah ini, lanjut ke: <strong>${steps[index + 1].title}</strong>` : '🎉 Selamat! PC kamu sudah siap digunakan!'}</p>
      </div>
    </div>
  `;

  panel.classList.add('show');
  panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function closeDetail() {
  document.getElementById('detailPanel').classList.remove('show');
  document.querySelectorAll('.component-card, .step-card').forEach(c => c.classList.remove('active'));
}
</script>
</body>
</html>
